# ──────────────────────────────────────
# SignalHub APIs — Environment Variables
# ──────────────────────────────────────

# Database
DATABASE_URL=postgresql+asyncpg://signalhub:signalhub_dev@localhost:5432/signalhub
DATABASE_URL_SYNC=postgresql://signalhub:signalhub_dev@localhost:5432/signalhub

# API
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://127.0.0.1:3000","http://127.0.0.1:3001"]

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Connectors (optional)
COINGECKO_API_KEY=

# Open-Meteo (fixed location for V1)
OPEN_METEO_LATITUDE=52.52
OPEN_METEO_LONGITUDE=13.41
